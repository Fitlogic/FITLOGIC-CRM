{
  "extends": [
    "next/core-web-vitals",
    "next/typescript"
  ],
  "rules": {
    // Disable TypeScript strict any rules
    "@typescript-eslint/no-explicit-any": "off",
    
    // Disable unused variable rules (many imports are for future use)
    "@typescript-eslint/no-unused-vars": "off",
    
    // Disable unescaped entities rules (too many false positives)
    "react/no-unescaped-entities": "off",
    
    // Disable empty interface rules
    "@typescript-eslint/no-empty-object-type": "off",
    
    // Disable unused expression rule
    "@typescript-eslint/no-unused-expressions": "off",
    
    // Disable React hooks exhaustive deps (too many false positives)
    "react-hooks/exhaustive-deps": "off",
    
    // Allow img elements (Next.js img optimization not always needed)
    "@next/next/no-img-element": "off"
  }
}
